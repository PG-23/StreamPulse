# Twitch Configuration
# Twitch token is an access token that can be generated from https://twitchtokengenerator.com/ (Scopes are chat:read and chat:edit)
TWITCH_TOKEN=oauth:YOUR_TOKEN_HERE
TWITCH_NICKNAME=your_twitch_username_lowercase
TWITCH_CHANNELS=#channel1,#channel2

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=twitch_chat
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_password

# Ingestion Settings
BATCH_SIZE=100
BATCH_INTERVAL_SECONDS=60
RAW_DATA_PATH=./data/raw