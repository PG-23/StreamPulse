# =============================================================================
# StreamPulse Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running the pipeline.
# Never commit .env to version control — it contains secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Twitch IRC Credentials
# -----------------------------------------------------------------------------
# Generate an OAuth token at https://twitchtokengenerator.com/
# Required scopes: chat:read and chat:edit
# Token must be prefixed with "oauth:" exactly as shown below.
TWITCH_TOKEN=oauth:your_token_here

# Your Twitch username in lowercase (e.g. "johndoe", not "JohnDoe")
TWITCH_NICKNAME=your_twitch_username_lowercase

# Comma-separated list of channels to monitor, each prefixed with "#"
# Example: #hasanabi,#loltyler1,#n3on
TWITCH_CHANNELS=#channel1,#channel2


# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
# Default values below match the Docker Compose setup.
# Change only if you are connecting to an external database.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=twitch_chat
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_password


# -----------------------------------------------------------------------------
# Ingestion Settings
# -----------------------------------------------------------------------------
# BATCH_SIZE: number of messages to accumulate before writing a JSON file
# BATCH_INTERVAL_SECONDS: max seconds between flushes regardless of batch size
# A batch is flushed when either threshold is reached first.
BATCH_SIZE=100
BATCH_INTERVAL_SECONDS=60

# Path where raw JSON batch files are written by the listener
# and read by the loader. Relative to the ingestion/ directory.
RAW_DATA_PATH=./data/raw